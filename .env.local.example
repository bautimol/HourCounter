# Supabase
# Get these values from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push (VAPID)
#
# Generate a key pair once with:
#   npx web-push generate-vapid-keys
#
# Then paste the values below. The PUBLIC key is also exposed to the
# browser via NEXT_PUBLIC_VAPID_PUBLIC_KEY (same value, different prefix
# so client code can read it).
#
# VAPID_SUBJECT must be a mailto: URL or an https:// URL identifying you
# as the push sender. Required by the spec — anything reachable works.
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
